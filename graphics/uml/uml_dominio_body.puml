' Pagina 1: modelo de dominio
title Modelo de dominio

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam nodesep 40
skinparam ranksep 35
skinparam linetype ortho
top to bottom direction

enum OptionType {
  Call
  Put
}

package "Activos" as PKG_ASSET {
  abstract class Asset {
    # name, initialPrice
    + getName(), getInitialPrice()
    + {abstract} simulateFinalValue(...)
    + {abstract} generatePath(...)
    + recordsIntermediatePrices()
  }

  class GBMAsset {
    - driftSpread, volatility
  }

  class EuropeanOption {
    - underlyingInitialPrice, strike
    - driftSpread, volatility, type
  }

  class BarrierOption {
    - underlyingInitialPrice, strike, barrier
    - driftSpread, volatility
  }

  class CouponBond {
    - faceValue, couponRate, maturity
    - currentYTM, yieldVol
    - rateModel (opcional)
  }

  Asset <|-- GBMAsset
  Asset <|-- EuropeanOption
  Asset <|-- BarrierOption
  Asset <|-- CouponBond
  EuropeanOption --> OptionType
}

package "Cartera" as PKG_CART {
  class Position <<struct>> {
    + asset: shared_ptr<Asset>
    + quantity: double
  }

  class Portfolio {
    - positions: vector<Position>
    - initialValue: double
    + addPosition(...)
    + simulatePathPnL(...)
  }

  Portfolio *-- "1..*" Position
}

package "Tipos de interes" as PKG_IR {
  interface InterestRateModel {
    + simulateShortRatePath(...)
    + discountFactorFromPath(...)
    + zeroCouponBondPrice(...)
    + initialShortRate()
  }

  class HullWhiteModel {
    - meanReversion, volatility, r0
    + getCurve()
  }

  class YieldCurve {
    - times, zeroRates
    + zeroRate(t), discountFactor(t)
    + forwardRate(t)
  }

  InterestRateModel <|.. HullWhiteModel
  HullWhiteModel *-- YieldCurve
}

PKG_ASSET -[hidden]down- PKG_CART
PKG_IR -[hidden]left- PKG_ASSET

note right of Asset
  simulateFinalValue = hot path (Portfolio)
  generatePath = cold path (tests)
end note

note right of BarrierOption
  Up-and-out call
end note

note right of CouponBond
  YTM/yieldVol o Hull-White
  (ver InterestRateModel)
end note

note right of Position
  Cada posicion referencia
  un Asset concreto (pag. Activos)
end note
